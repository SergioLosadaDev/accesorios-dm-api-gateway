# ─── Entorno: PRODUCCIÓN ──────────────────────────────────────────────────────
# Estructura de referencia. Los valores reales se gestionan mediante
# GitHub Secrets o un secret manager (Vault, AWS SSM, etc.).
#
# NUNCA completar ni commitear este archivo con valores reales.
# En el servidor de producción, las variables se inyectan desde el pipeline CI/CD.

# ── Ambiente ──────────────────────────────────────────────────────────────────
ENVIRONMENT=prod
IMAGE_TAG=<inyectado por pipeline>

# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
GATEWAY_PORT=3000

# ── Servicios internos ────────────────────────────────────────────────────────
INVENTORY_SERVICE_URL=http://inventory-service:8082
SECURITY_SERVICE_URL=http://security-service:8081

# ── JWT ───────────────────────────────────────────────────────────────────────
# La clave pública RSA de producción se obtiene del Security Service (JWKS endpoint)
# o se inyecta como GitHub Secret: JWT_PUBLIC_KEY
JWT_PUBLIC_KEY=<GitHub Secret: JWT_PUBLIC_KEY>
JWT_ISSUER=accesorios-dm

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://accesorios-dm.com

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_TTL=60000
RATE_LIMIT_MAX=60

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=warn
