# ─── Entorno: DEVELOP ─────────────────────────────────────────────────────────
# Copia este archivo a .env antes de levantar el servicio:
#   cp .env.dev.example .env
#
# La clave JWT ya viene configurada para desarrollo local.
# Genera tokens de prueba con: node scripts/generate-dev-token.js
# (requiere haber clonado dm-deployment y ejecutado: node dm-deployment/scripts/generate-dev-token.js)

# ── Ambiente ──────────────────────────────────────────────────────────────────
ENVIRONMENT=dev
IMAGE_TAG=dev

# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
GATEWAY_PORT=3000

# ── Servicios internos ────────────────────────────────────────────────────────
# Usar nombre de contenedor si ambos corren en la misma red Docker,
# o localhost si el servicio corre fuera de Docker.
INVENTORY_SERVICE_URL=http://inventory-service:8082
SECURITY_SERVICE_URL=http://security-service:8081

# ── JWT (clave pública RSA — par de scripts/dev-private.pem) ─────────────────
# Esta clave es exclusiva para desarrollo local. No usar en QA ni producción.
JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\nMIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8AMIIBCgKCAQEAsJie3gEG0G5Dc4khgN/0\nWDeg8MHDYRJY355k23RwI7+lHuuiXIZ8Z8BXeTGCA4VUhk8iRvxPG6XcbWXvgEq7\nqu/TnWEsMhbOtI3S3QpwzjKlbBUcgb0HP/ZjpHc8cdhKx55aLXjxe3HdETibexN1\nKs3rHhA5Ooqf5f9HPkGHJnJryB4nIub1l3paaNx6tcDc3oGueDdy0efebuX3bLRA\nd7dPTDnoelYcfKdFHyDaLhsXowsjKENLJddnTPnMnvdYc9Dpad91SHY6IyMMkeJn\n1bVM+ZF3ChZrHEpR2rwMuGIJU/NF3az1LecPtFvunFqukfNI5zyLVArR/cxPWtAy\nVwIDAQAB\n-----END PUBLIC KEY-----
JWT_ISSUER=accesorios-dm

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:4200

# ── Rate limiting (más permisivo en dev) ──────────────────────────────────────
RATE_LIMIT_TTL=60000
RATE_LIMIT_MAX=500

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=debug
