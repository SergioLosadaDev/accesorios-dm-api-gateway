# ─── Server ───────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Internal services ────────────────────────────────
SECURITY_SERVICE_URL=http://security-service:8081
INVENTORY_SERVICE_URL=http://inventory-service:8082

# ─── JWT (RSA public key — PEM format, \n escaped) ────
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nMIIBIjANBgkq...\n-----END PUBLIC KEY-----"
JWT_ISSUER=accesorios-dm-security-service

# ─── CORS ─────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:4200

# ─── Rate limiting ────────────────────────────────────
RATE_LIMIT_TTL=60000
RATE_LIMIT_MAX=100
