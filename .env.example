# Gateway
PORT=8000
NODE_ENV=production
LOG_LEVEL=warn

# Allowed Origins (separados por coma)
ALLOWED_ORIGINS=https://accesoriosdm.com,https://www.accesoriosdm.com

# Inventory Service (PROD)
INVENTORY_HOST=accesorios-dm-inventory-service-prod
INVENTORY_PORT=8080

# Security Service (PROD)
SECURITY_HOST=accesorios-dm-security-prod
SECURITY_PORT=8888

# Payment Service (PROD)
PAYMENT_HOST=accesorios-dm-payment-prod
PAYMENT_PORT=9000