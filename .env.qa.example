# ─── Entorno: QA ──────────────────────────────────────────────────────────────
# Copia este archivo a .env.qa y completa los valores marcados con <completar>:
#   cp .env.qa.example .env.qa
#
# NUNCA commitear .env.qa con valores reales.

# ── Ambiente ──────────────────────────────────────────────────────────────────
ENVIRONMENT=qa
IMAGE_TAG=qa

# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
GATEWAY_PORT=3000

# ── Servicios internos ────────────────────────────────────────────────────────
INVENTORY_SERVICE_URL=http://inventory-service:8082
SECURITY_SERVICE_URL=http://security-service:8081

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_PUBLIC_KEY=<completar: clave publica RSA del entorno QA>
JWT_ISSUER=accesorios-dm

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=<completar: URL del frontend en QA, ej. https://qa.accesorios-dm.com>

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_TTL=60000
RATE_LIMIT_MAX=100

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
